'''Query from SQL table 'cars' '''

import sqlite3

DATABASE = "cars.db"

def print_cars():
    speed = input("What speed: ")
    with sqlite3.connect(DATABASE) as db:
        cursor = db.cursor()
        sql = "SELECT * FROM cars WHERE top_speed > ?;"
        cursor.execute(sql, (speed,))
        results = cursor.fetchall()
        
        for car in results:
            print(f"Cars with top speed above {speed}")
            print(f"Car Name: {car[1]}; Top Speed: {car[2]}")

if __name__ == '__main__':
    print_cars()
    print('hello world')